{
  "name": "@kavishdua/proctor",
  "version": "1.0.0",
  "description": "Catch AI agents gaming their test suites",
  "type": "module",
  "bin": {
    "proctor": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "dist",
    "proctor.schema.json",
    "src/skill/SKILL.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catfish-1234/proctor.git"
  },
  "keywords": [
    "proctor",
    "ai",
    "testing",
    "git-hook",
    "claude"
  ],
  "scripts": {
    "build": "tsup",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "drift-check": "node dist/cli.js drift-check",
    "verify:pack": "bash scripts/verify-pack.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@typescript-eslint/typescript-estree": "^8.62.1",
    "commander": "^15.0.0",
    "fast-glob": "3.3.3",
    "micromatch": "^4.0.8",
    "parse-diff": "0.12.0",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "26.1.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
