{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/catfish-1234/proctor/proctor.schema.json",
  "title": "Proctor Config",
  "description": "Configuration for proctor — AI agent test-tampering guard",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "array",
      "items": { "type": "string", "pattern": "^RH\\d{3}$" },
      "description": "Rule IDs to enable. Defaults to all rules.",
      "default": ["RH001","RH002","RH003","RH004","RH005","RH006","RH007","RH008","RH009","RH010","RH011"]
    },
    "testPathGlobs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns identifying test files.",
      "default": ["**/*.test.{ts,tsx,mts,cts,js,jsx,mjs,cjs}","**/*.spec.{ts,tsx,mts,cts,js,jsx,mjs,cjs}","test/**/*","tests/**/*","__tests__/**/*","**/test_*.py","**/*_test.py"]
    },
    "severity": {
      "type": "object",
      "additionalProperties": { "type": "string", "enum": ["error","warn","info"] },
      "description": "Per-rule severity overrides. Keys are rule IDs (e.g. 'RH006')."
    },
    "ignorePatterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File glob patterns to ignore entirely.",
      "default": []
    },
    "approvedTestChanges": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Allowlisted test-change descriptions (inline suppression backup).",
      "default": []
    },
    "aiModel": {
      "type": "string",
      "description": "Model ID used by the optional --ai judge. Defaults to claude-haiku-4-5-20251001."
    },
    "snapshotGlobs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns identifying snapshot/golden files for RH006. Overrides the built-in defaults."
    }
  },
  "additionalProperties": false
}
